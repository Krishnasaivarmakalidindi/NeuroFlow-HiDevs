      "title": "Resilience Circuit Breakers Status",
      "type": "state-timeline",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "circuit_breakers_open",
          "legendFormat": "{{provider}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
